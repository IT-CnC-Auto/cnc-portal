# ============================================================
# Care Net Consultants Portal — Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to GitHub
# ============================================================

# Supabase — get from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Make.com — get API key from make.com → Profile → API
MAKE_API_KEY=your-make-api-key
MAKE_ZONE=us2

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Care Net Portal"
NEXT_PUBLIC_APP_ORG="Care Net Consultants (Pty) Ltd"

# ============================================================
# POPIA NOTICE: These variables may contain personal data
# configurations. Store securely. Never commit real values.
# Protected under POPIA Act 4 of 2013.
# ============================================================
